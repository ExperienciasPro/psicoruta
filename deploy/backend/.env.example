# MongoDB — Conexión local (misma máquina VPS)
# Si MongoDB requiere autenticación, usar: mongodb://usuario:password@127.0.0.1:27017/psicoruta_db?authSource=admin
MONGODB_URI=mongodb://127.0.0.1:27017/psicoruta_db

# Database name
DB_NAME=psicoruta_db

# Auth token (matches Angular frontend)
AUTH_TOKEN=um_api_2026

# CORS origin
CORS_ORIGIN=https://psicoruta.com

# Port
PORT=3003
